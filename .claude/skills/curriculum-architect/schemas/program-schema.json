{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swimbuddz.com/schemas/program.json",
  "title": "Swimbuddz Program Curriculum",
  "description": "Schema for swim program curriculum generation",
  "type": "object",
  "required": ["program", "curriculum", "milestones", "skills_library"],
  "properties": {
    "program": {
      "type": "object",
      "description": "Program metadata and configuration",
      "required": ["name", "slug", "description", "level", "duration_weeks"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Display name of the program",
          "examples": ["Water Confidence", "Freestyle Fundamentals"]
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "URL-friendly identifier (lowercase, hyphens only)",
          "examples": ["water-confidence-beginner", "freestyle-fundamentals"]
        },
        "description": {
          "type": "string",
          "minLength": 50,
          "maxLength": 500,
          "description": "Marketing description (2-3 sentences, benefit-focused)"
        },
        "level": {
          "type": "string",
          "enum": ["beginner_1", "beginner_2", "intermediate", "advanced", "specialty"],
          "description": "Program difficulty level"
        },
        "duration_weeks": {
          "type": "integer",
          "minimum": 4,
          "maximum": 24,
          "description": "Total program duration in weeks"
        },
        "default_capacity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 10,
          "description": "Maximum students per cohort"
        },
        "currency": {
          "type": "string",
          "enum": ["NGN", "USD", "GBP", "EUR"],
          "default": "NGN",
          "description": "Currency for pricing"
        },
        "price_amount": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Price in currency minor units (e.g., kobo for NGN)"
        },
        "billing_type": {
          "type": "string",
          "enum": ["one_time", "subscription", "per_session"],
          "default": "one_time",
          "description": "How students are billed"
        },
        "session_duration_minutes": {
          "type": "integer",
          "minimum": 45,
          "maximum": 180,
          "default": 90,
          "description": "Duration of each session in minutes (90 recommended)"
        },
        "prep_materials": {
          "type": "object",
          "description": "Materials students should prepare before starting",
          "properties": {
            "required_equipment": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Equipment students must bring",
              "examples": [["Swim goggles", "Swimsuit", "Towel"]]
            },
            "optional_equipment": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Optional equipment that enhances learning"
            },
            "pre_program_reading": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": {"type": "string"},
                  "description": {"type": "string"},
                  "url": {"type": ["string", "null"]}
                }
              },
              "description": "Articles or resources to review before starting"
            },
            "safety_briefing": {
              "type": "string",
              "description": "Safety information provided before Week 1"
            }
          }
        }
      }
    },
    "curriculum": {
      "type": "array",
      "description": "Weekly curriculum structure",
      "items": {
        "type": "object",
        "required": ["week_number", "theme", "objectives", "lessons"],
        "properties": {
          "week_number": {
            "type": "integer",
            "minimum": 1,
            "description": "Sequential week number"
          },
          "theme": {
            "type": "string",
            "minLength": 5,
            "maxLength": 100,
            "description": "Descriptive theme for the week"
          },
          "objectives": {
            "type": "string",
            "minLength": 20,
            "description": "Clear, measurable learning goals for this week"
          },
          "equipment_required": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Equipment needed for this week's activities",
            "examples": [["kickboard", "noodles"], ["pull buoy"]]
          },
          "distance_milestone": {
            "type": ["string", "null"],
            "description": "Distance-based goal for this week (e.g., 'Kick 25m')",
            "examples": ["5m glide", "Kick 25m", "Swim 50m continuous", null]
          },
          "pool_depth": {
            "type": "string",
            "enum": ["shallow", "deep", "both"],
            "default": "both",
            "description": "Which pool area is used for this week"
          },
          "supplementary_activity": {
            "type": ["string", "null"],
            "description": "End-of-session activity (back float, treading). Only from Week 6+",
            "examples": ["Back float practice (10 min)", "Treading water (10 min)", null]
          },
          "lessons": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["title", "description", "duration_minutes", "skills"],
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 5,
                  "maxLength": 100,
                  "description": "Lesson title"
                },
                "description": {
                  "type": "string",
                  "minLength": 100,
                  "description": "Detailed lesson description with 'why' explanations"
                },
                "duration_minutes": {
                  "type": "integer",
                  "minimum": 30,
                  "maximum": 180,
                  "description": "Lesson duration in minutes"
                },
                "video_url": {
                  "type": ["string", "null"],
                  "format": "uri",
                  "description": "Optional instructional video URL"
                },
                "skills": {
                  "type": "array",
                  "items": {"type": "string"},
                  "minItems": 1,
                  "description": "Skills covered in this lesson (must exist in skills_library)"
                }
              }
            }
          }
        }
      }
    },
    "milestones": {
      "type": "array",
      "description": "Assessable learning outcomes",
      "items": {
        "type": "object",
        "required": ["name", "criteria", "order_index", "milestone_type", "required_evidence"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Short milestone name",
            "examples": ["Kick 25m with kickboard", "50m Continuous Swim"]
          },
          "criteria": {
            "type": "string",
            "minLength": 20,
            "description": "Specific, observable criteria for achievement"
          },
          "order_index": {
            "type": "integer",
            "minimum": 1,
            "description": "Order in which milestones should be achieved"
          },
          "milestone_type": {
            "type": "string",
            "enum": ["skill", "endurance", "technique", "assessment"],
            "description": "Category of milestone"
          },
          "required_evidence": {
            "type": "string",
            "enum": ["none", "video", "time_trial"],
            "description": "What evidence is needed to mark complete"
          },
          "rubric_json": {
            "type": ["object", "null"],
            "description": "Detailed scoring rubric for assessments",
            "properties": {
              "categories": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "weight", "criteria"],
                  "properties": {
                    "name": {"type": "string"},
                    "weight": {"type": "integer", "minimum": 0, "maximum": 100},
                    "criteria": {"type": "string"}
                  }
                }
              },
              "passing_score": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "notes": {"type": "string"}
            }
          }
        }
      }
    },
    "skills_library": {
      "type": "array",
      "description": "All skills referenced in the curriculum",
      "items": {
        "type": "object",
        "required": ["name", "category", "description"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Skill name (must be unique)"
          },
          "category": {
            "type": "string",
            "enum": ["water_confidence", "stroke", "safety", "technique", "endurance"],
            "description": "Skill category for organization"
          },
          "description": {
            "type": "string",
            "minLength": 20,
            "description": "Clear explanation of what this skill involves"
          }
        }
      }
    }
  }
}
